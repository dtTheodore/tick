# Copy to .env and fill in. `docker compose --env-file .env up -d --build`.
# .env is gitignored — never commit real secrets or the settler key.

# --- Public hostname for TLS (Caddy gets a Let's Encrypt cert for this) ---
# Free option, no domain: "<EC2_PUBLIC_IP>.sslip.io" (e.g. 13.213.45.67.sslip.io).
# Or your own domain pointed at the box's IP.
PUBLIC_HOST=

# --- Postgres (local container) ---
# Keep the password URL-safe (no @ : / # %) — it goes into a postgres:// DSN.
POSTGRES_USER=tick
POSTGRES_PASSWORD=changemelongrandom
POSTGRES_DB=tick

# --- Logging ---
RUST_LOG=info

# --- USDC on-chain settlement (ADR-0010) -----------------------------------
# This base file is points-only. To ENABLE USDC, copy onchain.env.example to
# onchain.env and fill it (it's loaded as an optional env_file by api + worker).
# Leaving it absent = points-only; the stack runs fully without any chain config.

# Host dirs mounted into api + worker for the `sui` / `walrus` CLIs (USDC mode).
# The Sui config's ACTIVE address MUST equal TICK_SETTLER_ADDRESS or the worker
# refuses to boot. Default to ./secrets/* (gitignored). Ignored in points-only.
SUI_CONFIG_DIR=./secrets/sui
WALRUS_CONFIG_DIR=./secrets/walrus
