# USDC on-chain mode (ADR-0010). Copy to onchain.env to ENABLE USDC; delete/rename
# it to run points-only. Read by both the api (deposit/withdraw) and the worker
# (settle). The mere PRESENCE of TICK_VAULT_PKG switches the worker into USDC mode,
# so this file must be ABSENT (not just blank) for points-only.
#
# Also provision the funded settler keystore under secrets/sui/sui_config/ (active
# address = TICK_SETTLER_ADDRESS) and the Walrus config under secrets/walrus/.

TICK_VAULT_PKG=
TICK_VAULT_ID=
TICK_SETTLER_CAP_ID=
TICK_SETTLER_ADDRESS=
TICK_QUOTE_TYPE=
TICK_CUSTODY_PB_ID=
SUI_RPC_URL=https://fullnode.testnet.sui.io:443
WALRUS_CONTEXT=testnet
WALRUS_STORE_EPOCHS=1
TICK_SETTLE_GAS_BUDGET=
TICK_WITHDRAW_GAS_BUDGET=60000000
